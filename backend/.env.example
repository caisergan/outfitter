# Database
# Use the same AWS PostgreSQL URL for both host-side commands and the Docker API container.
DATABASE_URL=postgresql+asyncpg://aws_user:aws_password@your-db-endpoint.us-east-1.rds.amazonaws.com:5432/outfitter?ssl=require
DOCKER_DATABASE_URL=postgresql+asyncpg://aws_user:aws_password@your-db-endpoint.us-east-1.rds.amazonaws.com:5432/outfitter?ssl=require
USE_EXTERNAL_DB=true

# Optional: used by the API container in `docker compose`.
# Leave blank for bundled local Postgres, or set it to your AWS RDS/Aurora URL.
DOCKER_DATABASE_URL=

# When `true`, `./start.sh` skips the bundled Postgres container and expects an external database.
USE_EXTERNAL_DB=false

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=your-256-bit-secret-change-in-production

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
KLING_API_KEY=kling-...

# Storage (Cloudflare R2 or AWS S3)
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=outfitter-media

# App
ENV=development
LOG_LEVEL=info
