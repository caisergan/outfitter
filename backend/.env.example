# Database
# Use the same AWS PostgreSQL URL for both host-side commands and the Docker API container.
DATABASE_URL=postgresql+asyncpg://aws_user:aws_password@your-db-endpoint.us-east-1.rds.amazonaws.com:5432/outfitter?ssl=require
DOCKER_DATABASE_URL=postgresql+asyncpg://aws_user:aws_password@your-db-endpoint.us-east-1.rds.amazonaws.com:5432/outfitter?ssl=require
USE_EXTERNAL_DB=true

# Optional: used by the API container in `docker compose`.
# Leave blank for bundled local Postgres, or set it to your AWS RDS/Aurora URL.
DOCKER_DATABASE_URL=

# When `true`, `./start.sh` skips the bundled Postgres container and expects an external database.
USE_EXTERNAL_DB=false

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=your-256-bit-secret-change-in-production

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
KLING_API_KEY=kling-...

# ── Storage ─────────────────────────────────────────────────────────────────
#
# AWS S3 (recommended for production)
# -------------------------------------
# Bucket prerequisites:
#   1. Create an S3 bucket. Disable "Block all public access" if serving images
#      directly from S3, or keep it private and use a CloudFront distribution.
#   2. Attach a bucket CORS policy to allow PUT from your admin/mobile origins:
#        [{"AllowedHeaders":["*"],"AllowedMethods":["PUT"],
#          "AllowedOrigins":["https://your-admin.example.com"],
#          "ExposeHeaders":[]}]
#   3. Create an IAM user or role with s3:PutObject (and s3:GetObject if private)
#      on arn:aws:s3:::<bucket>/*. Generate an access key for that identity.
#   4. Set STORAGE_PUBLIC_BASE_URL to your CloudFront URL or the public S3 URL.
#      This is the base used to build image_url values stored in catalog_items.
#
# For AWS S3: leave R2_ENDPOINT_URL blank (legacy variable name, normalized to
# AWS default endpoint resolution by the app); set STORAGE_REGION to your bucket region.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=<iam-access-key-id>
R2_SECRET_ACCESS_KEY=<iam-secret-access-key>
R2_BUCKET=outfitter-media
STORAGE_REGION=us-east-1
# Public delivery URL base — no trailing slash
# CloudFront example: https://d1234abcd.cloudfront.net
# Direct S3 example:  https://outfitter-media.s3.us-east-1.amazonaws.com
STORAGE_PUBLIC_BASE_URL=https://outfitter-media.s3.us-east-1.amazonaws.com
#
# Cloudflare R2 (S3-compatible alternative)
# ------------------------------------------
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=outfitter-media
# STORAGE_REGION=auto
# STORAGE_PUBLIC_BASE_URL=https://<account_id>.r2.cloudflarestorage.com/outfitter-media

# App
ENV=development
LOG_LEVEL=info
